POSTGRES_USER=expense
POSTGRES_PASSWORD=expense
POSTGRES_DB=expense_db

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_BUCKET=receipts
MINIO_USE_SSL=false

JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d

PORT=8000
FRONTEND_URL=http://localhost:3000

NEXT_PUBLIC_API_URL=http://localhost:8000

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite

# Optional: seed admin user
ADMIN_EMAIL=admin@expense.local
ADMIN_PASSWORD=Admin123!

# ============================================================
# Root .env.example — commit this, never commit .env
# Copy to .env and fill in real secrets before running.
# ============================================================

# --- Postgres ---
POSTGRES_USER=expense
POSTGRES_PASSWORD=expense
POSTGRES_DB=expense_db

# --- Database connection (used by backend service) ---
DB_HOST=postgres
DB_PORT=5432
DB_USER=expense
DB_PASSWORD=expense
DB_NAME=expense_db

# --- MinIO ---
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_BUCKET=receipts
MINIO_USE_SSL=false

# --- Backend ---
PORT=8000
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d
FRONTEND_URL=http://localhost:3000
OPENAI_API_KEY=
ADMIN_EMAIL=admin@expense.local
ADMIN_PASSWORD=Admin123!

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:8000
